{
    "name": "pagesify",
    "version": "3.1.0",
    "description": "Simple pagination algorithm",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./src/index.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build"
    },
    "author": {
        "name": "Ricardo Matias",
        "url": "https://github.com/ricardomatias"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ricardomatias/pagesify"
    },
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^25.3.3",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
